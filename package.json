{
  "name": "agents-kanban",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "AgentsKanban: Cloudflare Workers app for multi-repo task orchestration and agent-run execution",
  "scripts": {
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "dev": "vite",
    "preview": "vite preview",
    "start": "vite",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:workers": "vitest -c vitest.worker.config.ts",
    "bootstrap:single-tenant": "tsx scripts/bootstrap-single-tenant.ts"
  },
  "devDependencies": {
    "@cloudflare/sandbox": "*",
    "@cloudflare/vite-plugin": "^1.25.6",
    "@cloudflare/vitest-pool-workers": "^0.8.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0",
    "tsx": "^4.20.5"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "hono": "^4.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
